{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SmartOCR Pro",
  "version": "0.1.0",
  "identifier": "com.smartocr.pro",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SmartOCR Pro",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.svg"
    ],
    "resources": [
      "resources/ocr"
    ]
  }
}
